# ── Dependencies ─────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────
client/dist/
client/dist-ssr/

# ── Environment secrets ────────────────────
.env
**/.env
*.env.local
*.env.*.local

# ── Uploaded files (user data, not source) ─
server/uploads/*
!server/uploads/.gitkeep

# ── Prisma generated client ────────────────
server/node_modules/.prisma/

# ── Logs ──────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── OS files ──────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Python venv (if any) ──────────────────
venv/
__pycache__/
*.pyc
